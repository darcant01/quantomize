{
  "version": 2,
  "functions": {
    "api/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    { "src": "/api/auth",     "dest": "/api/auth.js" },
    { "src": "/api/products", "dest": "/api/products.js" },
    { "src": "/api/sales",    "dest": "/api/sales.js" },
    { "src": "/api/users",    "dest": "/api/users.js" },
    { "src": "/api/settings", "dest": "/api/settings.js" },
    { "src": "/app",          "dest": "/public/app.html" },
    { "src": "/login",        "dest": "/public/login.html" },
    { "src": "/",             "dest": "/public/login.html" }
  ]
}
